<?xml version="1.0"?>
<robot name="amr_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="$(find amr_description)/urdf/gazebo_control.xacro"/>

  <!-- =====================================================================
       Locked dimensions — sourced from CLAUDE.md. Do NOT change these.
       ===================================================================== -->
  <xacro:property name="base_length"    value="0.600"/>   <!-- X, front-back -->
  <xacro:property name="base_width"     value="0.500"/>   <!-- Y, side-side  -->
  <xacro:property name="base_height"    value="0.300"/>   <!-- Z             -->

  <xacro:property name="wheel_radius"   value="0.065"/>
  <xacro:property name="wheel_width"    value="0.040"/>
  <xacro:property name="wheel_y"        value="0.275"/>   <!-- |Y| from centre -->
  <xacro:property name="wheel_x"        value="-0.100"/>  <!-- rear-biased axle position -->

  <xacro:property name="caster_radius"  value="0.025"/>

  <!-- Scissor-lift platform -->
  <xacro:property name="lift_length"   value="0.400"/>   <!-- X -->
  <xacro:property name="lift_width"    value="0.400"/>   <!-- Y -->
  <xacro:property name="lift_height"   value="0.020"/>   <!-- Z (thin plate) -->

  <!-- RPLIDAR C1 — cylinder approximation -->
  <xacro:property name="lidar_radius"  value="0.050"/>
  <xacro:property name="lidar_height"  value="0.060"/>

  <!-- Orbbec Astra Pro — box approximation -->
  <xacro:property name="cam_length"    value="0.025"/>   <!-- X, depth into chassis -->
  <xacro:property name="cam_width"     value="0.080"/>   <!-- Y, horizontal span -->
  <xacro:property name="cam_height"    value="0.060"/>   <!-- Z, vertical span -->

  <!-- base_link centre sits this high above the ground (= wheel touches floor) -->
  <xacro:property name="base_z"  value="${wheel_radius + base_height / 2.0}"/>

  <!-- Caster joint drop below base_link centre so sphere bottom = 0 m -->
  <xacro:property name="caster_z"
    value="${-(base_height / 2.0) - (wheel_radius - caster_radius)}"/>

  <!-- =====================================================================
       Materials
       ===================================================================== -->
  <material name="dark_grey">  <color rgba="0.20 0.20 0.20 1.0"/> </material>
  <material name="black">      <color rgba="0.05 0.05 0.05 1.0"/> </material>
  <material name="light_grey"> <color rgba="0.75 0.75 0.75 1.0"/> </material>
  <material name="blue">       <color rgba="0.10 0.40 0.80 1.0"/> </material>

  <!-- =====================================================================
       Macro: drive wheel (cylinder, rotates about Y)
       params: name      — prefix used for link/joint names
               y_sign    — +1 for left, -1 for right
       ===================================================================== -->
  <xacro:macro name="drive_wheel" params="name y_sign">

    <link name="${name}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <!-- m=1 kg  cylinder axis=Y: Ixx=Izz=m/12*(3r²+l²)  Iyy=m/2*r² -->
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="1.0"/>
        <inertia ixx="0.001190" ixy="0" ixz="0"
                                 iyy="0.002113" iyz="0"
                                                 izz="0.001190"/>
      </inertial>
    </link>

    <!-- Wheel centre is at the bottom face of the base (same height as wheel_radius) -->
    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}_wheel_link"/>
      <origin xyz="${wheel_x} ${y_sign * wheel_y} ${-(base_height / 2.0)}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>

  </xacro:macro>

  <!-- =====================================================================
       Macro: passive caster (sphere, fixed joint)
       ===================================================================== -->
  <xacro:macro name="caster" params="name x_pos y_pos">

    <link name="${name}_caster_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
        <material name="light_grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
      </collision>
      <!-- m=0.1 kg  sphere: Ixx=Iyy=Izz=2/5*m*r² -->
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.1"/>
        <inertia ixx="0.000025" ixy="0" ixz="0"
                                 iyy="0.000025" iyz="0"
                                                 izz="0.000025"/>
      </inertial>
    </link>

    <joint name="${name}_caster_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="${name}_caster_link"/>
      <origin xyz="${x_pos} ${y_pos} ${caster_z}" rpy="0 0 0"/>
    </joint>

  </xacro:macro>

  <!-- =====================================================================
       base_footprint — virtual link at ground level (Z = 0)
       ===================================================================== -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${base_z}" rpy="0 0 0"/>
  </joint>

  <!-- =====================================================================
       base_link — chassis box (500 × 600 × 300 mm)
       ===================================================================== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <!-- m=15 kg  box: Ixx=m/12*(w²+h²)  Iyy=m/12*(l²+h²)  Izz=m/12*(l²+w²) -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="15.0"/>
      <inertia ixx="0.425000" ixy="0" ixz="0"
                               iyy="0.562500" iyz="0"
                                               izz="0.762500"/>
    </inertial>
  </link>

  <!-- =====================================================================
       Drive wheels  (left = +Y, right = −Y)
       ===================================================================== -->
  <xacro:drive_wheel name="left"  y_sign=" 1"/>
  <xacro:drive_wheel name="right" y_sign="-1"/>

  <!-- =====================================================================
       Passive casters at the four chassis corners
       X: ±240 mm inset from ends   Y: ±180 mm inset from sides
       ===================================================================== -->
  <xacro:caster name="front_left"  x_pos=" 0.240" y_pos=" 0.180"/>
  <xacro:caster name="front_right" x_pos=" 0.240" y_pos="-0.180"/>
  <xacro:caster name="rear_left"   x_pos="-0.240" y_pos=" 0.180"/>
  <xacro:caster name="rear_right"  x_pos="-0.240" y_pos="-0.180"/>

  <!-- =====================================================================
       Scissor-lift platform
       lift_joint origin places the platform flush on top of base_link at q=0:
         Z = base_height/2 + lift_height/2 = 0.150 + 0.010 = 0.160 m
       Prismatic displacement adds along +Z, max stroke 0.5 m.
       ===================================================================== -->
  <link name="lift_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${lift_length} ${lift_width} ${lift_height}"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${lift_length} ${lift_width} ${lift_height}"/>
      </geometry>
    </collision>
    <!-- m=2 kg  box 0.400×0.400×0.020 -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.026733" ixy="0" ixz="0"
                               iyy="0.026733" iyz="0"
                                               izz="0.053333"/>
    </inertial>
  </link>

  <joint name="lift_joint" type="prismatic">
    <parent link="base_link"/>
    <child  link="lift_link"/>
    <origin xyz="0 0 ${base_height / 2.0 + lift_height / 2.0}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="0.5" effort="100" velocity="0.1"/>
  </joint>

  <!-- =====================================================================
       RPLIDAR C1  (topic: /scan)
       Sits on top of the chassis, forward of centre.
       Joint Z = base_height/2 + lidar_height/2 → cylinder bottom flush with chassis top.
       ===================================================================== -->
  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
    </collision>
    <!-- m=0.2 kg  cylinder axis=Z: Ixx=Iyy=m/12*(3r²+h²)  Izz=m/2*r² -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.000185" ixy="0" ixz="0"
                               iyy="0.000185" iyz="0"
                                               izz="0.000250"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <origin xyz="0.25 0 ${base_height / 2.0 + lidar_height / 2.0}" rpy="0 0 0"/>
  </joint>

  <!-- =====================================================================
       Orbbec Astra Pro depth camera  (topic: /camera/depth/points)
       Mounted on the front face of base_link, centred on the chassis height,
       facing forward (+X). Origin X = 0.3 m = front edge of base_link.
       ===================================================================== -->
  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${cam_length} ${cam_width} ${cam_height}"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${cam_length} ${cam_width} ${cam_height}"/>
      </geometry>
    </collision>
    <!-- m=0.2 kg  box 0.025×0.080×0.060 -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.000167" ixy="0" ixz="0"
                               iyy="0.000070" iyz="0"
                                               izz="0.000117"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <origin xyz="0.3 0 0" rpy="0 0 0"/>
  </joint>

</robot>
